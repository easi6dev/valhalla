# =============================================================================
# Valhalla Tile Pipeline Configuration
# =============================================================================
# Copy this file to pipeline.local.conf (local dev) or pipeline.<env>.conf
# and fill in the paths for your environment.
#
# Load order (first found wins):
#   1. --pipeline-config <path> CLI flag
#   2. VALHALLA_PIPELINE_CONFIG env var
#   3. config/pipeline/pipeline.<VALHALLA_ENV>.conf  (VALHALLA_ENV=local|dev|test|staging|prod)
#   4. config/pipeline/pipeline.local.conf           (fallback default)
#
# NEVER commit pipeline.local.conf, pipeline.staging.conf, pipeline.prod.conf
# Only pipeline.conf.example is committed to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Environment identifier (local | dev | test | staging | prod)
# ---------------------------------------------------------------------------
VALHALLA_ENV=local

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------

# Root directory where per-region tile subdirectories are created.
# Structure: VALHALLA_TILE_DIR/<region>/*.gph
# Local example:   /mnt/c/Users/you/Workspace/valhallaV3/data/valhalla_tiles
# Staging/prod:    /var/valhalla/tiles
VALHALLA_TILE_DIR=/mnt/c/Users/yourname/Workspace/valhallaV3/data/valhalla_tiles

# Directory where OSM .pbf files are stored.
# Naming convention: <region>-latest.osm.pbf  (e.g. singapore-latest.osm.pbf)
# Local example:   /mnt/c/Users/you/Workspace/valhallaV3/data/osm
# Staging/prod:    /var/valhalla/osm
OSM_DIR=/mnt/c/Users/yourname/Workspace/valhallaV3/data/osm

# Directory for admin boundary SQLite databases (admins.sqlite, timezones.sqlite).
# Local example:   /mnt/c/Users/you/Workspace/valhallaV3/data/admin_data
# Staging/prod:    /var/valhalla/admin
VALHALLA_ADMIN_DIR=/mnt/c/Users/yourname/Workspace/valhallaV3/data/admin_data

# Directory for build logs.
VALHALLA_LOG_DIR=/mnt/c/Users/yourname/Workspace/valhallaV3/logs

# ---------------------------------------------------------------------------
# Build options
# ---------------------------------------------------------------------------

# Skip elevation data during tile build (true = faster builds, no height data)
SKIP_ELEVATION=true

# Clean existing tiles before building (true = full rebuild)
CLEAN_BUILD=false

# ---------------------------------------------------------------------------
# S3 / Object storage (staging and prod only — leave blank for local)
# ---------------------------------------------------------------------------

# S3 bucket where finished tiles are uploaded.
# Leave blank to skip S3 upload.
# Example: s3://your-company-valhalla/tiles
S3_TILE_BUCKET=

# AWS region for the S3 bucket
S3_REGION=ap-southeast-1

# ---------------------------------------------------------------------------
# Valhalla binary
# ---------------------------------------------------------------------------

# Path to valhalla_build_tiles binary.
# Leave blank to use system PATH or Docker fallback.
# Local (built from source): /mnt/c/Users/you/Workspace/valhallaV3/build/src/valhalla_build_tiles
VALHALLA_BUILD_TILES_BIN=

# Docker image to use when valhalla_build_tiles binary is not found.
VALHALLA_DOCKER_IMAGE=ghcr.io/valhalla/valhalla:latest
